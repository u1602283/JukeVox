SPOTIFY__ClientId=your_spotify_client_id
SPOTIFY__ClientSecret=your_spotify_client_secret
SPOTIFY__RedirectUri=https://jukevox-dev.scottp.dev:5001/api/auth/callback
# ASPNETCORE_URLS is not needed when cert.pem/key.pem are present (Kestrel auto-configures port 5001)
ASPNETCORE_URLS=https://127.0.0.1:5001
ASPNETCORE_ENVIRONMENT=Development

# Frontend URL (used for CORS and OAuth callback redirect)
FRONTENDURL=https://jukevox-dev.scottp.dev:5173

# WebAuthn relying party config
HOSTAUTH__ServerDomain=jukevox-dev.scottp.dev
HOSTAUTH__Origins=https://jukevox-dev.scottp.dev:5173
